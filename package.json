{
  "name": "roleforge-ai-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "smoke:frontend": "node scripts/smoke_frontend.mjs",
    "smoke:checkout": "node scripts/smoke_live_checkout.mjs",
    "smoke:layout": "node scripts/smoke_layout.mjs",
    "smoke:readiness": "node scripts/check_smoke_readiness.mjs",
    "check:billing": "node scripts/check_billing_launch_readiness.mjs",
    "check:billing:vercel": "node scripts/check_billing_launch_readiness.mjs --vercel-production --strict",
    "check:entitlement": "node scripts/check_premium_entitlement.mjs",
    "create:promo": "node scripts/create_live_promo_code.mjs",
    "support:inbox": "node scripts/list_support_requests.mjs",
    "support:status": "node scripts/update_support_request_status.mjs",
    "set:billing:vercel": "node scripts/set_vercel_billing_env.mjs",
    "set:support:vercel": "node scripts/set_vercel_support_env.mjs",
    "typecheck": "tsc --noEmit",
    "wait:vercel": "node scripts/wait_for_vercel_status.mjs",
    "test": "tsx --test app/lib/*.test.ts app/lib/billing/*.test.ts app/lib/supabase/*.test.ts scripts/*.test.mjs",
    "test:billing": "tsx --test app/lib/billing/entitlements.test.ts",
    "test:billing-display": "tsx --test app/lib/billing/display.test.ts",
    "test:exports": "tsx --test app/lib/exportFormats.test.ts",
    "test:history": "tsx --test app/lib/history.test.ts",
    "test:redirects": "tsx --test app/lib/safeRedirect.test.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.2",
    "typescript": "^5"
  }
}
